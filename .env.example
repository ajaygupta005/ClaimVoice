# Postgres
POSTGRES_USER=claimvoice
POSTGRES_PASSWORD=changeme
POSTGRES_DB=claimvoice
DATABASE_URL=postgresql://claimvoice:changeme@localhost:5433/claimvoice

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=claimvoice

# Langfuse (run langfuse first, then create a project and paste keys here)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_NEXTAUTH_SECRET=change-me-in-prod
LANGFUSE_SALT=change-me-in-prod

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Anthropic Claude (paid-but-cheap; uses free credits for dev)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Voice stack (real adapters are key-gated; unset = deterministic mock fallback)
DEEPGRAM_API_KEY=your-deepgram-api-key
CARTESIA_API_KEY=sk_car_xxxxxxxxxxxxxxxxxxxx

# Voyage AI — embeddings for SBC RAG (voyage-4-large, 200M tokens/month free)
# Get key at https://dash.voyageai.com
VOYAGE_API_KEY=

# Voyage AI — embeddings for SBC RAG (voyage-4-large, 200M tokens/month free)
# Get key at https://dash.voyageai.com
VOYAGE_API_KEY=

# Run-mode toggles for WS-4/5/6 (all default to "mock"; set to enable real paths)
VOICE_AGENT_ANSWER_MODE=mock
TOOL_MODE=mock
FACT_CHECK_MODE=mock
STT_MODE=mock
TTS_MODE=mock

# Inter-service URLs (voice-agent -> eligibility/providers)
ELIGIBILITY_BASE_URL=http://localhost:8002
PROVIDERS_BASE_URL=http://localhost:8003
